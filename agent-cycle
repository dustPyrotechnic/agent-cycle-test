#!/usr/bin/env bash
set -euo pipefail

ENGINE_REPOSITORY="${AGENT_ENGINE_REPOSITORY:-dustPyrotechnic/agent-cycle-test}"
ENGINE_REF="${AGENT_ENGINE_REF:-v1}"

fail() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Manage the Agent Cycle shortcut and deploy it from any target repository.

Usage:
  agent-cycle setup [--bin-dir DIR] [--force]
  agent-cycle deploy [shortcut options] [install.sh options]
  agent-cycle cancel-release [TAG] --yes [--engine-repository OWNER/REPO]
  agent-cycle help

Commands:
  setup           Install this shortcut and its bundled deployer.
  deploy          Deploy Agent Cycle from the current target repository root.
  cancel-release  Delete a GitHub Release and its remote tag.

Deploy shortcut options:
  --dev                         Use the central engine's main branch.
  --engine-repository OWNER/REPO
                                Override the central engine repository.
  --engine-ref REF              Override the engine tag or commit SHA.
  --public-engine               Do not configure the private-engine token.
  --no-commit                   Do not commit and push the listener.

All other deploy options are forwarded to install.sh. Production deployments
default to the private dustPyrotechnic/agent-cycle-test@v1 engine and commit the
listener.
EOF
}

setup_shortcut() {
  local bin_dir="${AGENT_CYCLE_BIN_DIR:-${HOME}/.local/bin}"
  local force=false
  local source_dir=""
  local source_path=""
  local installer_source=""
  local destination=""
  local installer_destination=""

  while (($#)); do
    case "$1" in
      --bin-dir)
        (($# >= 2)) || fail "--bin-dir requires a value"
        bin_dir="$2"
        shift 2
        ;;
      --force)
        force=true
        shift
        ;;
      -h | --help)
        usage
        return
        ;;
      *)
        fail "unknown setup option: $1"
        ;;
    esac
  done

  source_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  source_path="${source_dir}/$(basename "${BASH_SOURCE[0]}")"
  destination="${bin_dir}/agent-cycle"
  installer_destination="${bin_dir}/agent-cycle-install.sh"
  if [[ -f "${source_dir}/install.sh" ]]; then
    installer_source="${source_dir}/install.sh"
  elif [[ -f "${source_dir}/agent-cycle-install.sh" ]]; then
    installer_source="${source_dir}/agent-cycle-install.sh"
  fi

  mkdir -p "$bin_dir"
  if [[ -e "$destination" ]] && ! cmp -s "$source_path" "$destination" && [[ "$force" != true ]]; then
    fail "${destination} already exists and differs; rerun setup with --force"
  fi
  if [[ -n "$installer_source" && -e "$installer_destination" ]] &&
    ! cmp -s "$installer_source" "$installer_destination" && [[ "$force" != true ]]; then
    fail "${installer_destination} already exists and differs; rerun setup with --force"
  fi

  if [[ "$source_path" != "$destination" ]]; then
    install -m 0755 "$source_path" "$destination"
  fi
  if [[ -n "$installer_source" && "$installer_source" != "$installer_destination" ]]; then
    install -m 0755 "$installer_source" "$installer_destination"
  fi

  printf 'Installed Agent Cycle shortcut: %s\n' "$destination"
  if [[ -n "$installer_source" ]]; then
    printf 'Installed bundled deployer: %s\n' "$installer_destination"
  fi
  case ":${PATH}:" in
    *":${bin_dir}:"*) ;;
    *)
      printf 'Add this directory to PATH before using the command:\n'
      printf '  export PATH="%s:%s"\n' "$bin_dir" "\$PATH"
      ;;
  esac
}

deploy() {
  local engine_repository="$ENGINE_REPOSITORY"
  local engine_ref="$ENGINE_REF"
  local private_engine=true
  local commit_listener=true
  local script_dir=""
  local installer=""
  local downloaded_installer=""
  local -a installer_args=()
  local -a forwarded_args=()

  while (($#)); do
    case "$1" in
      --dev)
        engine_ref=main
        shift
        ;;
      --engine-repository)
        (($# >= 2)) || fail "--engine-repository requires a value"
        engine_repository="$2"
        shift 2
        ;;
      --engine-ref)
        (($# >= 2)) || fail "--engine-ref requires a value"
        engine_ref="$2"
        shift 2
        ;;
      --private-engine)
        private_engine=true
        shift
        ;;
      --public-engine)
        private_engine=false
        shift
        ;;
      --commit)
        commit_listener=true
        shift
        ;;
      --no-commit)
        commit_listener=false
        shift
        ;;
      -h | --help)
        usage
        return
        ;;
      --)
        shift
        forwarded_args+=("$@")
        break
        ;;
      *)
        forwarded_args+=("$1")
        shift
        ;;
    esac
  done

  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "${script_dir}/agent-cycle-install.sh" ]]; then
    installer="${script_dir}/agent-cycle-install.sh"
  elif [[ -f "${script_dir}/install.sh" ]]; then
    installer="${script_dir}/install.sh"
  else
    command -v gh >/dev/null 2>&1 || fail "gh is required to download the central installer"
    printf 'Fetching Agent Cycle installer from %s@%s...\n' "$engine_repository" "$engine_ref"
    downloaded_installer="$(mktemp)"
    trap 'rm -f "$downloaded_installer"' EXIT
    gh api \
      --method GET \
      -H "Accept: application/vnd.github.raw+json" \
      "repos/${engine_repository}/contents/install.sh" \
      -f "ref=${engine_ref}" >"$downloaded_installer"
    installer="$downloaded_installer"
  fi

  installer_args=(
    --engine-repository "$engine_repository"
    --engine-ref "$engine_ref"
  )
  if [[ "$private_engine" == true ]]; then
    installer_args+=(--private-engine)
  fi
  if [[ "$commit_listener" == true ]]; then
    installer_args+=(--commit)
  fi

  if ((${#forwarded_args[@]})); then
    bash "$installer" "${installer_args[@]}" "${forwarded_args[@]}"
  else
    # Bash 3.2 treats an empty "${array[@]}" as unbound under set -u.
    bash "$installer" "${installer_args[@]}"
  fi
  if [[ -n "$downloaded_installer" ]]; then
    rm -f "$downloaded_installer"
    trap - EXIT
  fi
}

cancel_release() {
  local engine_repository="$ENGINE_REPOSITORY"
  local tag="v1"
  local tag_set=false
  local confirmed=false
  local current_repository=""

  while (($#)); do
    case "$1" in
      --engine-repository)
        (($# >= 2)) || fail "--engine-repository requires a value"
        engine_repository="$2"
        shift 2
        ;;
      --yes)
        confirmed=true
        shift
        ;;
      -h | --help)
        usage
        return
        ;;
      -*)
        fail "unknown cancel-release option: $1"
        ;;
      *)
        [[ "$tag_set" != true ]] || fail "cancel-release accepts only one tag"
        tag="$1"
        tag_set=true
        shift
        ;;
    esac
  done

  [[ "$engine_repository" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]] ||
    fail "invalid engine repository: ${engine_repository}"
  [[ "$tag" =~ ^[A-Za-z0-9._/-]+$ ]] ||
    fail "invalid release tag: ${tag}"
  [[ "$confirmed" == true ]] ||
    fail "cancel-release deletes ${engine_repository}@${tag}; rerun with --yes to confirm"

  command -v gh >/dev/null 2>&1 || fail "gh is required to cancel a release"
  gh release view "$tag" --repo "$engine_repository" >/dev/null ||
    fail "GitHub Release ${engine_repository}@${tag} does not exist"

  gh release delete "$tag" \
    --repo "$engine_repository" \
    --cleanup-tag \
    --yes

  current_repository="$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null || true)"
  if [[ "$current_repository" == "$engine_repository" ]] &&
    git show-ref --verify --quiet "refs/tags/${tag}"; then
    git tag -d "$tag" >/dev/null
    printf 'Deleted local tag: %s\n' "$tag"
  fi

  printf 'Cancelled release: %s@%s\n' "$engine_repository" "$tag"
}

command_name="${1:-help}"
if (($#)); then
  shift
fi

case "$command_name" in
  setup)
    setup_shortcut "$@"
    ;;
  deploy)
    deploy "$@"
    ;;
  cancel-release)
    cancel_release "$@"
    ;;
  help | -h | --help)
    usage
    ;;
  *)
    fail "unknown command: ${command_name}; run 'agent-cycle help'"
    ;;
esac
